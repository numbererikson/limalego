# Default to LF on checkout for cross-platform consistency
* text=auto eol=lf

# Force LF for shell scripts and systemd units (they're consumed on Linux)
*.sh        text eol=lf
*.service   text eol=lf
*.timer     text eol=lf
*.template  text eol=lf

# Binary-ish files: never touch
*.png  binary
*.jpg  binary
*.jpeg binary
*.webp binary
*.gif  binary
*.ico  binary
*.db   binary
