{
  "expo": {
    "name": "Limalego",
    "slug": "limalego",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "limalego",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.limalego.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Limalego uses the camera to recognise LEGO parts."
      }
    },
    "android": {
      "package": "com.limalego.app",
      "permissions": ["CAMERA"]
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Limalego uses the camera to recognise LEGO parts."
        }
      ]
    ]
  }
}
